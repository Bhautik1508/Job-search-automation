# Google Gemini API (Phase 2)
GEMINI_API_KEY=your_gemini_api_key_here

# Apify API (Phase 1)
APIFY_API_TOKEN=your_apify_api_token_here

# Apify Actor Tuning (Phase 4.5)
APIFY_ACTOR_TIMEOUT=180
APIFY_MAX_ITEMS=50
APIFY_ENABLE_BANKING_QUERIES=true
APIFY_CREDIT_WARNING=0.50

# Instahyre (Phase 4.4)
INSTAHYRE_EMAIL=your_instahyre_email_here
INSTAHYRE_PASSWORD=your_instahyre_password_here
INSTAHYRE_HEADLESS=true
INSTAHYRE_TIMEOUT_MS=30000
INSTAHYRE_MAX_PAGES=5

# Database
DATABASE_URL=sqlite:///data/jobs.db

# Scraping Configuration
SCRAPE_INTERVAL_HOURS=4
TARGET_CITIES=Bangalore,Mumbai,Delhi NCR,Hyderabad,Pune
